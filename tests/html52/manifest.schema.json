{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://broiler-html.local/tests/html52/manifest.schema.json",
  "title": "Broiler.HTML HTML 5.2 Plain-HTML Test Suite Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "suite", "defaults", "cases"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "suite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "description", "standard"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "standard": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "version", "snapshotDate", "url"],
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" },
            "snapshotDate": { "type": "string" },
            "url": { "type": "string", "format": "uri" }
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["viewports", "fonts", "tolerance"],
      "properties": {
        "viewports": {
          "type": "array",
          "items": { "$ref": "#/$defs/viewport" }
        },
        "fonts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tolerance": { "$ref": "#/$defs/tolerance" }
      }
    },
    "generatedManifests": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "cases": {
      "type": "array",
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "cluster",
        "spec",
        "input",
        "assertions",
        "expectations",
        "status",
        "scripts"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "cluster": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "subcluster": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "featureId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "spec": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/specReference" }
        },
        "input": {
          "type": "string",
          "minLength": 1
        },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "expectations": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "tokens": { "type": "string" },
            "dom": { "type": "string" },
            "css": { "type": "string" },
            "computedStyle": { "type": "string" },
            "layout": { "type": "string" },
            "displayList": { "type": "string" },
            "render": { "type": "string" },
            "resourceLog": { "type": "string" },
            "semanticOutline": { "type": "string" },
            "negative": { "type": "string" }
          }
        },
        "viewports": {
          "type": "array",
          "items": { "$ref": "#/$defs/viewport" }
        },
        "fonts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tolerance": { "$ref": "#/$defs/tolerance" },
        "requires": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scripts": {
          "enum": ["not-required", "markup-only", "forbidden"]
        },
        "status": {
          "enum": ["planned", "active", "optional", "quarantined", "blocked", "out-of-scope"]
        },
        "quarantine": {
          "type": "object",
          "additionalProperties": false,
          "required": ["owner", "expires", "reason"],
          "properties": {
            "owner": { "type": "string", "minLength": 1 },
            "expires": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "reason": { "type": "string", "minLength": 1 },
            "issue": { "type": "string" }
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "specReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section", "url"],
      "properties": {
        "section": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "deviceScaleFactor"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "deviceScaleFactor": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "tolerance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pixelDiffThreshold", "colorTolerance"],
      "properties": {
        "pixelDiffThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "colorTolerance": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        }
      }
    }
  }
}
