{
  "name": "broiler.html",
  "version": "1.0.0",
  "description": "Playwright-based non-JS WPT runner for Broiler.HTML compliance checks.",
  "scripts": {
    "test": "node --test scripts/wpt/*.test.mjs",
    "html52:coverage": "node ./scripts/html52/summarize-coverage.mjs",
    "html52:css": "node ./scripts/html52/run-suite.mjs --cluster css --cluster layout --cluster painting --cluster text-i18n --cluster css-modules",
    "html52:css-coverage": "node ./scripts/html52/generate-css-module-coverage.mjs",
    "html52:css-coverage:check": "node ./scripts/html52/generate-css-module-coverage.mjs --check",
    "html52:css-registry": "node ./scripts/html52/generate-css-module-registry.mjs",
    "html52:css-registry:check": "node ./scripts/html52/generate-css-module-registry.mjs --check",
    "html52:css-breadth": "node ./scripts/html52/run-suite.mjs --cluster css-modules --include phase3-renderer-breadth",
    "html52:css-drafts": "node ./scripts/html52/run-suite.mjs --cluster css-modules --include phase4-draft-early",
    "html52:css-stable": "node ./scripts/html52/run-suite.mjs --cluster css-modules --include phase2-stable-core",
    "html52:dashboard": "node ./scripts/html52/update-compliance-dashboard.mjs",
    "html52:dashboard:check": "node ./scripts/html52/update-compliance-dashboard.mjs --check",
    "html52:parser": "node ./scripts/html52/run-suite.mjs --cluster syntax --cluster tree-construction",
    "html52:run": "node ./scripts/html52/run-suite.mjs",
    "html52:smoke": "node ./scripts/html52/run-suite.mjs --include phase4 --include phase6",
    "html52:validate": "node ./scripts/html52/validate-manifest.mjs",
    "html52:visual": "node ./scripts/html52/run-suite.mjs --include phase2-visual",
    "html52:phase3": "node ./scripts/html52/run-suite.mjs --include phase3",
    "html52:phase4": "node ./scripts/html52/run-suite.mjs --include phase4",
    "html52:phase5": "node ./scripts/html52/run-suite.mjs --include phase5",
    "html52:phase6": "node ./scripts/html52/run-suite.mjs --include phase6",
    "html52:repeat": "node ./scripts/html52/run-suite.mjs --repeat 2",
    "wpt:prepare": "node ./scripts/wpt/prepare-wpt.mjs",
    "wpt:run": "node ./scripts/wpt/run-non-js.mjs",
    "wpt:install-browsers": "playwright install chromium"
  },
  "private": true,
  "type": "module",
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
